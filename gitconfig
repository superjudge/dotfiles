[core]
  excludesfile = ~/.gitignore

[alias]
  co = checkout
  st = status
  wc = whatchanged
  br = branch

  lg = log --graph
  lp = log -p

[color]
  ui = auto

[push]
  default = current

[merge]
  tool = meld

[diff]
  tool = opendiff
