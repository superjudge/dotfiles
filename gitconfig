[user]
  name = Johan Liseborn
  email = johan.liseborn@gmail.com

[core]
  excludesfile = ~/.gitignore
  eol = lf
  #autocrlf = input
  #safecrlf = true

[alias]
  co = checkout
  st = status
  wc = whatchanged
  br = branch

  lg = log --graph
  lp = log -p

  sha = log --pretty=sha -1

  vanity = shortlog -n -s

[color]
  ui = auto

[push]
  default = current

[merge]
  tool = opendiff

[diff]
  tool = opendiff

[pretty]
  sha = format:%h
